domain_loyalty_views:
    tables:
      - table_ref: pcb-{env}-landing.domain_loyalty.PC_LOYALTY_SUBSCRIPTIONS
        view_ref: pcb-{env}-curated.domain_loyalty.PC_LOYALTY_SUBSCRIPTIONS
        view_sql: "
                    Select
                      customerId,
                      name,
                      accountId,
                      eventType,
                      errorCode,
                      DATETIME(eventDate) as eventDate,
                      INGESTION_TIMESTAMP
                    from pcb-{env}-landing.domain_loyalty.PC_LOYALTY_SUBSCRIPTIONS;
                  "
      - table_ref: pcb-{env}-landing.domain_loyalty.PC_OPTIMUM_WALLET_EVENT
        view_ref: pcb-{env}-curated.domain_loyalty.PC_OPTIMUM_WALLET_EVENT
        view_sql: "
                    Select
                      eventType,
                      pcfCustomerId,
                      customerId,
                      walletId,
                      walletStatus,
                      pcoErrorCode,
                      INGESTION_TIMESTAMP
                    from pcb-{env}-landing.domain_loyalty.PC_OPTIMUM_WALLET_EVENT;
                  "
      - table_ref: pcb-{env}-landing.domain_loyalty.PC_POINTS_AWARDED
        view_ref: pcb-{env}-curated.domain_loyalty.PC_POINTS_AWARDED
        view_sql: "
                    Select
                      pcPoints.id,
                      pcfCustomerIdCluster as pcfCustomerId,
                      pcPoints.customerId,
                      pcPoints.campaignId,
                      pcPoints.externalCampaignId,
                      pcPoints.points,
                      DATETIME(transactionDatePartition, substr(pcPoints.transactionDate, -6, 6)) as transactionDate,
                      pcPoints.description,
                      pcPoints.externalId,
                      pcPoints.transactionOrigin,
                      pcPoints.cardHash,
                      memberId,
                      pointEventId,
                      pointEventReference,
                      INGESTION_TIMESTAMP
                    from pcb-{env}-landing.domain_loyalty.PC_POINTS_AWARDED;
                  "
      - table_ref: pcb-{env}-landing.domain_loyalty.PC_POINTS_REPROCESS
        view_ref: pcb-{env}-curated.domain_loyalty.PC_POINTS_REPROCESS
        view_sql: "
                    Select
                      pcPoints.id,
                      pcfCustomerIdCluster as pcfCustomerId,
                      pcPoints.customerId,
                      pcPoints.campaignId,
                      pcPoints.externalCampaignId,
                      pcPoints.points,
                      DATETIME(transactionDatePartition, substr(pcPoints.transactionDate, -6, 6)) as transactionDate,
                      pcPoints.description,
                      pcPoints.externalId,
                      pcPoints.transactionOrigin,
                      pcPoints.cardHash,
                      pcoErrorCode,
                      failureReasonCode,
                      INGESTION_TIMESTAMP
                    from pcb-{env}-landing.domain_loyalty.PC_POINTS_REPROCESS;
                  "

