      - table_ref: pcb-{env}-landing.domain_validation_verification.APPLICANT_PERSONAL_IDENTIFIER
        view_ref: pcb-{env}-curated.domain_validation_verification.APPLICANT_PERSONAL_IDENTIFIER
      - table_ref: pcb-{env}-landing.domain_validation_verification.IDV_REQUEST
        view_ref: pcb-{env}-curated.domain_validation_verification.IDV_REQUEST
      - table_ref: pcb-{env}-landing.domain_validation_verification.IDV_SUBMISSION
        view_ref: pcb-{env}-curated.domain_validation_verification.IDV_SUBMISSION
      - table_ref: pcb-{env}-landing.domain_validation_verification.IDV_EVENT
        view_ref: pcb-{env}-curated.domain_validation_verification.IDV_EVENT
      - table_ref: pcb-{env}-landing.domain_validation_verification.IDV_DOCUMENT
        view_ref: pcb-{env}-curated.domain_validation_verification.IDV_DOCUMENT
      - table_ref: pcb-{env}-landing.domain_validation_verification.CUSTOMER_ID_VERIFICATION
        view_ref: pcb-{env}-curated.domain_validation_verification.CUSTOMER_ID_VERIFICATION
        view_sql: "
                    SELECT
                      * EXCEPT(optype, row_num, position, timestamp, currenttimestamp)
                    FROM
                      (
                        SELECT
                          *,
                          ROW_NUMBER() OVER(PARTITION BY CUSTOMER_UID ORDER BY position DESC) AS row_num
                        FROM
                          `pcb-{env}-landing.domain_validation_verification.CUSTOMER_ID_VERIFICATION`
                      )
                    WHERE
                      row_num = 1
                      AND optype <> 'D'
                  "

domain_communication_views:
    tables:
      - table_ref: pcb-{env}-landing.domain_communication.COMMUNICATION_EVENT
        view_ref: pcb-{env}-curated.domain_communication.COMMUNICATION_EVENT
        view_sql: "
                    SELECT
                    requestId, notificationCode,
                    contactStrategyCode, language,
                    source, sourceId, domainCode,
                    customerId, pcfCustomerId,
                    accountId, tsysCustomerId,
                    tsysAccountId, productCode,
                    lastDigits, timezone,
                    statusChannel, statusCode,
                    statusResponse, statusMessage,
                    statusTimestamp, statusContact,
                    statusExternalId, statusElapsedTime,
                    message_id, subscription_name,
                    attributes,
                    publish_time,
                    data FROM pcb-{env}-landing.domain_communication.COMMUNICATION_EVENT
                    where cast(publish_time as date) < DATE_ADD(CURRENT_DATE(), INTERVAL 1 DAY);
                  "
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION_ACCOUNT
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION_ACCOUNT
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION_CUSTOMER
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION_CUSTOMER
      - table_ref: pcb-{env}-landing.domain_communication.REF_NOTIFI_CHANNEL_CD
        view_ref: pcb-{env}-curated.domain_communication.REF_NOTIFI_CHANNEL_CD
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION_REQ_PARAM
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION_REQ_PARAM
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION_REQ_EVENT
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION_REQ_EVENT
      - table_ref: pcb-{env}-landing.domain_communication.NOTIFICATION_REQUEST
        view_ref: pcb-{env}-curated.domain_communication.NOTIFICATION_REQUEST
      - table_ref: pcb-{env}-landing.domain_communication.COMMUNICATION_REQUEST
        view_ref: pcb-{env}-curated.domain_communication.COMMUNICATION_REQUEST
        view_sql: "
                    SELECT
                    requestId, notificationCode,
                    contactStrategyCode, language,
                    source, sourceId, channels,
                    primaryPhone, alternatePhone,
                    email, pushToken, domainCode,
                    customerId, pcfCustomerId,
                    accountId, tsysCustomerId,
                    tsysAccountId, productCode,
                    lastDigits, timezone,
                    additionalIdentifiers,
                    parameters, message_id,
                    subscription_name,
                    attributes,
                    publish_time,
                    data FROM pcb-{env}-landing.domain_communication.COMMUNICATION_REQUEST
                    where cast(publish_time as date) < DATE_ADD(CURRENT_DATE(), INTERVAL 1 DAY);
                  "

