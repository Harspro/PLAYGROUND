spark_job:
  jar_file_uris:
    - gs://pcb-{env}-staging-artifacts/jarfiles/table-comparator-2.0.0.jar
  file_uris:
    - gs://pcb-{env}-staging-artifacts/resources/table-comparator/application.yaml
  main_class: com.pcb.batch.spark.table.comparator.ComparatorSparkBatchApplication
  application_config: application.yaml
  job_history_path: gs://pcb-{env}-staging-extract/job_history/

dag:
  schedule_interval: '0 8 * * *'

test-cases:
  - case.name: ODS-ADDRESS-CONTACT-HISTORY-001
    source.database: ODS
    source.table: CARDINAL.ADDRESS_CONTACT_HISTORY
    bigquery.table: pcb-{env}-curated:ODSDataset.ADDRESS_CONTACT_HISTORY
    select.columns: ADDRESS_CONTACT_HISTORY_UID,CONTACT_UID
    is.enabled: False
  - case.name: ODS-CONTACT-HISTORY-001
    source.database: ODS
    source.table: CARDINAL.CONTACT_HISTORY
    bigquery.table: pcb-{env}-curated:ODSDataset.CONTACT_HISTORY
    select.columns: CONTACT_HISTORY_UID,CONTACT_UID
    is.enabled: False
  - case.name: ODS-CUSTOMER-EMPLOYMENT-HISTORY-001
