    select.columns: EMAIL_CONTACT_HISTORY_UID,CONTACT_UID
    is.enabled: False
  - case.name: ODS-PHONE-CONTACT-HISTORY-001
    source.database: ODS
    source.table: CARDINAL.PHONE_CONTACT_HISTORY
    bigquery.table: pcb-{env}-curated:ODSDataset.PHONE_CONTACT_HISTORY
    select.columns: PHONE_CONTACT_HISTORY_UID,CONTACT_UID
    is.enabled: False
  - case.name: ODS-POLITICAL-EXPOSED-POSITION-001
    source.database: ODS
    source.table: CARDINAL.POLITICAL_EXPOSED_POSITION
    bigquery.table: pcb-{env}-curated:ODSDataset.POLITICAL_EXPOSED_POSITION
