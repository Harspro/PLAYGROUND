    source.table: CARDINAL.CUSTOMER_EMPLOYMENT_HISTORY
    bigquery.table: pcb-{env}-curated:ODSDataset.CUSTOMER_EMPLOYMENT_HISTORY
    select.columns: CUSTOMER_EMP_HISTORY_UID,CUSTOMER_EMPLOYMENT_UID
    is.enabled: False
  - case.name: ODS-CUSTOMER-HISTORY-001
    source.database: ODS
