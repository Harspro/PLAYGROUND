db839_custom_contact_detail_records_table_delta:
  is_sqlserver: True
  fetch_spark_job:
    dbname: db839
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: IVRReport.dbo.CUSTOM_CONTACT_DETAIL_RECORDS
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: CALLSTARTDATETIME
  bigquery:
    project_id: pcb-prod-pds
    dataset_id: sql_server_tables
    table_name: CUSTOM_CONTACT_DETAIL_RECORDS
    add_columns:
      - '`Interval` as INTERVAL_ID'
    drop_columns:
      - Interval
  batch:
    time_from: '05:00:00'
    time_to: '05:00:00'
  dag:
    schedule_interval: '35 5 * * *'
  default_args:
    owner: "team-centaurs"
    capability: "PDS"

