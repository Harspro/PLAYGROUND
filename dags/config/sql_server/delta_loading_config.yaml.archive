db839_store_attributed_dm_table_delta:
  is_sqlserver: True
  fetch_spark_job:
    dbname: db839
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: Generic.dbo.STORE_ATTRIBUTED_DM
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: CIFP_DATE_OPEN
  bigquery:
    project_id: pcb-prod-pds
    dataset_id: sql_server_tables
    table_name: STORE_ATTRIBUTED_DM
  batch:
    time_from: '05:00:00'
    time_to: '05:00:00'
  dag:
    schedule_interval: '10 5 * * *'
  default_args:
    owner: "team-centaurs"
    capability: "Data Movement PDS"

