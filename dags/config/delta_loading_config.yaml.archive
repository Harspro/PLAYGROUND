data_patch_ods_application_product_table:
  fetch_spark_job:
    dbname: ods
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: APPLMGMT.APPLICATION_PRODUCT
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: CREATE_DT
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_customer_acquisition
    table_name: APPLICATION_PRODUCT
    add_columns:
      - CAST(APPLICATION_PRODUCT_UID AS INT64) AS APPLICATION_PRODUCT_UID
      - CAST(APPLICATION_SUBMISSION_UID AS INT64) AS APPLICATION_SUBMISSION_UID
      - TSYS_REFERENCE_NUMBER AS TSYS_REFERENCE_NUMBER
      - ACCOUNT_NO AS ACCOUNT_NO
      - PRODUCT_CODE AS PRODUCT_CODE
      - CREATE_DT AS CREATE_DT
      - CREATE_USER_ID AS CREATE_USER_ID
      - CREATE_FUNCTION_NAME AS CREATE_FUNCTION_NAME
      - UPDATE_DT AS UPDATE_DT
      - UPDATE_USER_ID AS UPDATE_USER_ID
      - UPDATE_FUNCTION_NAME AS UPDATE_FUNCTION_NAME
      - PRODUCT_TYPE AS PRODUCT_TYPE
      - CURRENT_STATUS AS CURRENT_STATUS
      - CURRENT_CONTEXT AS CURRENT_CONTEXT
      - ACCOUNT_OPEN_DT AS ACCOUNT_OPEN_DT
      - SENDER_DT AS SENDER_DT
      - IDV_REQUEST_NO AS IDV_REQUEST_NO
      - CORRESPONDENCE_CODE AS CORRESPONDENCE_CODE
      - E_DELIVERY_IND AS E_DELIVERY_IND
      - INTENDED_USE_OF_ACCT AS INTENDED_USE_OF_ACCT
      - SPECIAL_STATUS AS SPECIAL_STATUS
      - STRUCT(
        STRING(NULL) AS STREAM_NAME,
        INT64(NULL) AS TOPIC_PARTITION,
        INT64(NULL) AS PARTITION_OFFSET,
        INT64(NULL) AS STREAM_OFFSET,
        INT64(NULL) AS OFFSET_DIFF,
        STRING(NULL) AS ENVIRONMENT,
        INT64(NULL) AS TOPIC_VERSION,
        STRING(NULL) AS USERVICE_CORRELATION_ID,
        STRING(NULL) AS USERVICE_TRACEABILITY_ID
        ) AS METADATA
      - DATETIME(NULL) AS INGESTION_TIMESTAMP
    drop_columns:
      - APPLICATION_PRODUCT_UID
      - APPLICATION_SUBMISSION_UID
      - TSYS_REFERENCE_NUMBER
      - ACCOUNT_NO
      - PRODUCT_CODE
      - CREATE_DT
      - CREATE_USER_ID
      - CREATE_FUNCTION_NAME
      - UPDATE_DT
      - UPDATE_USER_ID
      - UPDATE_FUNCTION_NAME
      - PRODUCT_TYPE
      - CURRENT_STATUS
      - CURRENT_CONTEXT
      - ACCOUNT_OPEN_DT
      - SENDER_DT
      - IDV_REQUEST_NO
      - CORRESPONDENCE_CODE
      - E_DELIVERY_IND
      - INTENDED_USE_OF_ACCT
      - SPECIAL_STATUS
  dag:
    schedule_interval: null
  default_args:
    owner: "team-growth-and-sales-alerts"
    capability: "CustomerAcquisition"
    sub_capability: "Applications"
    business_impact: "NA"
    customer_impact: "NA"
    severity: 'P3'
  tags:
    - team-growth-and-sales

