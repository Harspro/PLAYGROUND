ods_cardinal_cust_alert_notification_table_delta:
  fetch_spark_job:
    dbname: ods
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: CARDINAL.CUST_ALERT_NOTIFICATION
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: UPDATE_DT
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_communication
    table_name: CUST_ALERT_NOTIFICATION
  batch:
    time_from: '8:00:00'
    time_to: '8:00:00'
  dag:
    schedule_interval: '35 8 * * *'
  default_args:
    owner: "team-telegraphers-alerts"
    capability: "communication"
    sub_capability: "push-notification"
    business_impact: "NA"
    customer_impact: "NA"

