db053_ts2_pc_download_table_delta:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.PC_DOWNLOAD
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_LOAD_DT_TM_STMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: PC_DOWNLOAD
    add_columns:
      - PARSE_DATE('%Y%m%d', CAST(10000*YYYY + 100*MM + DD AS STRING)) AS FILE_CREATE_DT
      - REC_LOAD_DT_TM_STMP AS REC_LOAD_TIMESTAMP
    drop_columns:
      - YYYY
      - MM
      - DD
      - REC_LOAD_DT_TM_STMP
  batch:
    time_from: '8:00:00'
    time_to: '8:00:00'
  dag:
    schedule_interval: '25 8 * * *'
  default_args:
    owner: "team-centaurs"
    capability: "Data Movement PDS"

