      - SAFE_CAST(TSYSINP_SC01_COUNT AS INT64) AS TSYSINP_SC01_COUNT
      - SAFE_CAST(TSYSINP_SC31_COUNT AS INT64) AS TSYSINP_SC31_COUNT
      - SAFE_CAST(TSYSINP_SC32_COUNT AS INT64) AS TSYSINP_SC32_COUNT
      - SAFE_CAST(CB_FILE_NUMBER AS STRING) AS CB_FILE_NUMBER
    drop_columns:
      - FILE_CREATION_DATE_TIME
      - TSYSINP_SC01_COUNT
      - TSYSINP_SC31_COUNT
      - TSYSINP_SC32_COUNT
      - CB_FILE_NUMBER

