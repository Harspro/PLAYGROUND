adm_adm_std_disp_empm_info_backfilling_job:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.query: "SELECT a.*, l.SOURCE_END_DT_CURR FROM ADM.ADM_STD_DISP_EMPM_INFO a JOIN ADM.LOAD_RESULT l ON a.V9SEQ = l.PROCESS_NUM AND l.TABLE_NM='ADM_STD_DISP_EMPM_INFO' WHERE TRUNC(a.REC_CREATE_TMS) = TO_DATE('2016-08-31', 'YYYY-MM-DD')"
      pcb.bigquery.loader.source.db.read.parallelism: 1
  bigquery:
    dataset_id: domain_customer_acquisition
    table_name: ADM_STD_DISP_EMPM_INFO
    add_columns:
      - V9SEQ AS EXECUTION_ID
      - DATE(SOURCE_END_DT_CURR) AS FILE_CREATE_DT
