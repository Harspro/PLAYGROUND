# finished dags have been archived
db909_scms_tkm_cmn_module_flavour_loading_job:
  fetch_spark_job:
    dbname: db909_ogres
    args:
      pcb.bigquery.loader.source.query: "SELECT MODULE_NAME, FLAVOUR_NAME, IND_ACTIVE FROM SCMS_TKM.CMN_MODULE_FLAVOUR"
      pcb.bigquery.loader.source.db.read.parallelism: 1
  bigquery:
    dataset_id: cots_scms_tkm
    table_name: CMN_MODULE_FLAVOUR
    overwrite_bq_table: True
  default_args:
    owner: "team-ogres-alerts"

