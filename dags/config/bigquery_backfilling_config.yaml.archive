    dbname: db303
    args:
      pcb.bigquery.loader.source.query: "SELECT  '7607' as CLIENT_ID , '9999' as RECORD_TYPE, TSYSINP_TYPE_SC01, TSYSINP_SC01_COUNT, TSYSINP_TYPE_SC31, TSYSINP_SC31_COUNT, TSYSINP_TYPE_SC32, TSYSINP_SC32_COUNT, CB_FILE_NUMBER,
                                          FILE_CREATION_DATE_TIME FROM RISK.CREDSCORE_FILEINFO
                                          WHERE TRUNC(FILE_CREATION_DATE_TIME) > '2016-01-01' and FILE_NAME_PREFIX IN ('expcbanktsystt.eqxcan.ds.SC10', 'expcbanktsyspd.eqxcan.ds.SC10')"
      pcb.bigquery.loader.source.db.read.parallelism: 1
