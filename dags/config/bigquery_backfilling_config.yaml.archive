credscore_das_header_trlr_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.query: "SELECT NULL as BTDR_RECORD_CODE, 0 as BTDR_SUB_CC, 0 as BTDR_SUB_YY, 0 as BTDR_SUB_MM, 0 as BTDR_SUB_DD, 0 as BTDR_SUB_TIME, NULL as BTDR_CUSTOMER_ID,
                                          NULL as BTDR_PROCESS_CODE, NULL as BTDR_RUN_TYPE, NULL as BTDR_PROCESS_INFO, FILE_NAME_PREFIX as SOURCE_FILE_PREFIX1, CB_FILE_NUMBER, REC_CREATE_ID, CYCLE,
                                          FILE_CREATION_DATE_TIME, NUMBER_DETAIL_RECORDS, NUMBER_TOTAL_RECORDS, FILE_NAME_PREFIX as SOURCE_FILE_NAME, CYCLE_MONTH, CYCLE_YEAR
                                          FROM RISK.CREDSCORE_FILEINFO
                                          WHERE TRUNC(FILE_CREATION_DATE_TIME) > '2016-01-01' and FILE_NAME_PREFIX IN ('expcbanktsystt.eqxcan.ds.SCDS', 'expcbanktsyspd.eqxcan.ds.SCDS')"
      pcb.bigquery.loader.source.db.read.parallelism: 1
  bigquery:
    dataset_id: domain_scoring
    table_name: CREDSCORE_DAS_HEADER_TRLR
    overwrite_bq_table: True
    add_columns:
      - DATE(FILE_CREATION_DATE_TIME) AS FILE_CREATE_DT
      - FILE_CREATION_DATE_TIME AS REC_LOAD_TIMESTAMP
      - SAFE_CAST(BTDR_SUB_CC AS INT64) AS BTDR_SUB_CC
      - SAFE_CAST(BTDR_SUB_YY AS INT64) AS BTDR_SUB_YY
      - SAFE_CAST(BTDR_SUB_MM AS INT64) AS BTDR_SUB_MM
      - SAFE_CAST(BTDR_SUB_DD AS INT64) AS BTDR_SUB_DD
      - SAFE_CAST(BTDR_SUB_TIME AS INT64) AS BTDR_SUB_TIME
      - SAFE_CAST(CB_FILE_NUMBER AS INT64) AS FILE_NUMBER
      - SAFE_CAST(CB_FILE_NUMBER AS INT64) AS CB_FILE_NUMBER
      - SAFE_CAST(REC_CREATE_ID AS INT64) AS REC_ID
      - SAFE_CAST(CYCLE AS INT64) AS CYCLE_DAY
      - SAFE_CAST(NUMBER_DETAIL_RECORDS AS INT64) AS NUMBER_DETAIL_RECORDS
      - SAFE_CAST(NUMBER_TOTAL_RECORDS AS INT64) AS NUMBER_TOTAL_RECORDS
      - SAFE_CAST(CYCLE_MONTH AS INT64) AS CYCLE_MONTH
      - SAFE_CAST(CYCLE_YEAR AS INT64) AS CYCLE_YEAR
    drop_columns:
      - FILE_CREATION_DATE_TIME
      - BTDR_SUB_CC
      - BTDR_SUB_YY
      - BTDR_SUB_MM
      - BTDR_SUB_DD
      - BTDR_SUB_TIME
      - CB_FILE_NUMBER
      - REC_CREATE_ID
      - CYCLE
      - NUMBER_DETAIL_RECORDS
      - NUMBER_TOTAL_RECORDS
      - CYCLE_MONTH
      - CYCLE_YEAR

db610_date_format_check:
  fetch_spark_job:
    dbname: db610_pds
