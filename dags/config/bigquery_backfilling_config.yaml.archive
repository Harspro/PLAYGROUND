adm_p053_adm_std_disp_empm_info_backfilling_job:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.query: "SELECT * FROM ADM_P053.ADM_STD_DISP_EMPM_INFO WHERE V9SEQ NOT IN (SELECT DISTINCT PROCESS_NUM FROM ADM.LOAD_RESULT WHERE TABLE_NM='ADM_STD_DISP_EMPM_INFO')"
      pcb.bigquery.loader.source.db.read.parallelism: 1
  bigquery:
    dataset_id: domain_customer_acquisition
    table_name: ADM_STD_DISP_EMPM_INFO
    add_columns:
      - V9SEQ AS EXECUTION_ID
      - DATE(REC_CREATE_TMS) AS FILE_CREATE_DT
    drop_columns:
      - V9SEQ
      - LOAD_RESULT_UUID

