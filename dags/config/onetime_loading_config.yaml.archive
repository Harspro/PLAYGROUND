db839_national_store_list_onetime_loading_job:
  is_sqlserver: True
  jar_file_uris:
    - gs://pcb-{env}-staging-artifacts/jarfiles/ods-bigquery-connector-2.0.0.jar
  file_uris:
    - gs://pcb-{env}-staging-artifacts/resources/ods-bigquery-connector/application-pds-pr839.conf
  main_class: com.pcb.batch.odsbigqueryconnector.ODSToGCSConnector
  application_config: application-pds-pr839.conf
  args:
    pcb.bigquery.loader.source.schema.qualified.tablename: Generic.dbo.National_Store_List
    pcb.bigquery.loader.source.primary.key.column: PROCESS_DATE
    pcb.bigquery.loader.source.db.read.parallelism: 8
  gcs:
    bucket: pcb-{env}-staging-extract
    staging_folder: generic
  default_args:
    owner: "team-centaurs"
    capability: "PDS"
  bigquery:
    project_id: pcb-prod-pds
    dataset_id: sql_server_tables
    table_name: NATIONAL_STORE_LIST
    add_columns:
      - Fl_p_Banner AS FLIP_BANNER
      - Owner_s_Email_ AS OWNERS_EMAIL
      - '`Union` AS UNION_NM'
      - Pharm_ AS PHARM_NUM
      - Service_Director_Directeur__service___la_client_le AS Service_Director
      - Fresh_Specialist___Bakery__Floral___Garden_Sp_cialiste_des_produits_frais____Boulangerie AS Fresh_SPL_BAKERY_FLORAL_GARDEN
      - Fresh_Specialist__Produce__Sp_cialiste_des_produits_frais____Fruits_et_l_gumes_Floral AS FRESH_SPL_PRODUCE
      - Health___Safety_Business_Partners_les_partenaires_d_affaires_sant__et_s_curit_ AS HEALTH_SAFETY_BUSINESS_PARTENRS
      - SAP_Store__ AS SAP_STORE
      - SAP_Drugstore__ AS SAP_DRUGSTORE
      - Doctors_Line_ AS DOCTORS_LINE
      - Store_Main_ AS STORE_MAIN
      - SCRIPTPRO_ AS SCRIPTPRO
      - MEDSLINK___Autoapproval__Opt_in_Opt_out_ AS MEDSLINK_AUTOAPPROVAL_OPT_IN_OUT
      - _CENTRAL__Vial_ AS CENTRAL_VIAL
      - CLINIC_DESIGN_ AS CLINIC_DESIGN
    drop_columns:
      - Fl_p_Banner
      - Owner_s_Email_
      - Union
      - Pharm_
      - Service_Director_Directeur__service___la_client_le
      - Fresh_Specialist___Bakery__Floral___Garden_Sp_cialiste_des_produits_frais____Boulangerie
      - Fresh_Specialist__Produce__Sp_cialiste_des_produits_frais____Fruits_et_l_gumes_Floral
      - Health___Safety_Business_Partners_les_partenaires_d_affaires_sant__et_s_curit_
      - SAP_Store__
      - SAP_Drugstore__
      - Doctors_Line_
      - Store_Main_
      - SCRIPTPRO_
      - MEDSLINK___Autoapproval__Opt_in_Opt_out_
      - _CENTRAL__Vial_
      - CLINIC_DESIGN_

