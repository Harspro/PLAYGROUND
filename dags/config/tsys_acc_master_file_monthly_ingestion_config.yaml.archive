        pcb.tsys.processor.copybook.path: gs://pcb-{env}-staging-artifacts/copybooks/tsys_pcb_mc_acctmaster_full/MSTACCT_AM00.cpy
        pcb.tsys.processor.segment.name: AM00
        pcb.tsys.processor.layout.name: AM00_REC
