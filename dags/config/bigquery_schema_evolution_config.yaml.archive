  dataset_id: domain_customer_acquisition
  table_name: EXPERIAN_PCMC_REGISTRATION
  partition_field: RANGE_BUCKET(PC_MC_CUST_APPL_ID, GENERATE_ARRAY(0, 2147483647, 500000))
  transformations:
