domain_card_management_INSTANT_ISSUANCE_DAGS_CONTROL_schema_udpate:
  default_args:
    owner: "gremlins"
    capability: "account-management'"
    sub_capability: "card-management'"
    business_impact: "This will impact instant card issuance for SCMS"
    customer_impact: "NA"
  tags:
    - gremlins
  project_id: pcb-{env}-landing
  dataset_id: domain_card_management
  table_name: INSTANT_ISSUANCE_DAGS_CONTROL
  transformations:
    - column:
        add_columns:
          - TIMESTAMP(NULL) AS dagExecutionTime
          - STRING(NULL) AS triggerType
          - INT64(NULL) AS replacementCount