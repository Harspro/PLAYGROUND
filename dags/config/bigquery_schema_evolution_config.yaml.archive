billpay_fulfillment_change_timestamp_to_datetime:
  project_id: pcb-{env}-landing
  dataset_id: domain_payments
  table_name: BILLPAY_FULFILLMENT
  transformations:
    - column:
        add_columns:
          - DATETIME(TIMESTAMP(FUNDSMOVE_PROCESSING_DT) , 'America/Toronto') AS FUNDSMOVE_PROCESSING_DT
          - DATETIME(TIMESTAMP(CREATE_DT) , 'America/Toronto') AS CREATE_DT
          - DATETIME(TIMESTAMP(UPDATE_DT) , 'America/Toronto') AS UPDATE_DT
        drop_columns:
          - FUNDSMOVE_PROCESSING_DT
          - CREATE_DT
          - UPDATE_DT

billpay_opacct_req_change_timestamp_to_datetime:
