at31_schema_migration:
  project_id: pcb-{env}-landing
  dataset_id: domain_account_management
  table_name: AT31
  partition_field: FILE_CREATE_DT
  clustering_fields:
    - MAST_ACCOUNT_ID
    - AT31_DATE_TRANSACTION
    - AT31_TRANSACTION_CODE
    - AT31_MERCHANT_ID
  transformations:
    - timestamp

experian_aml_canada_post_schema_migration:
  project_id: pcb-{env}-landing
  dataset_id: domain_customer_acquisition
  table_name: EXPERIAN_AML_CANADA_POST
  partition_field: DATE_TRUNC(DELIVERY_DATE, MONTH)
  transformations:
    - timestamp

aml_trnx_agg_control_ts_to_datetime:
  project_id: pcb-{env}-processing
