    - column:
        add_columns:
          - DATETIME(TIMESTAMP(REQUEST_ON) , 'America/Toronto') AS REQUEST_ON
          - DATETIME(TIMESTAMP(PYMT_DT) , 'America/Toronto') AS PYMT_DT
          - DATETIME(TIMESTAMP(CREATE_DT) , 'America/Toronto') AS CREATE_DT
          - DATETIME(TIMESTAMP(UPDATE_DT) , 'America/Toronto') AS UPDATE_DT
        drop_columns:
          - REQUEST_ON
          - PYMT_DT
          - CREATE_DT
          - UPDATE_DT

