  dataset_id: domain_customer_acquisition
  table_name: ADM_STD_DISP_DT_ELMT
  clustering_fields:
    - ELE_ELEMENT_NAME
    - APA_APP_NUM

gen_val_detail_adjust_clustering:
  project_id: pcb-{env}-landing
  dataset_id: domain_customer_acquisition
  table_name: GEN_VAL_DETAIL
  clustering_fields:
    - ELEMENT_NAME
    - APP_NUM

transaction_feed_control_table_add_columns:
  project_id: pcb-{env}-processing
  dataset_id: domain_aml
  table_name: TRANSACTION_FEED_CONTROL_TABLE
  transformations:
    - column:
        add_columns:
          - CASE
              WHEN RUN_ID LIKE 'scheduled%' THEN 'scheduled'
              WHEN RUN_ID LIKE 'manual%' THEN 'manual'
            END AS DAG_RUN_TYPE
          - FEED AS RAIL_TYPE
        drop_columns:
          - JOB_NAME
          - FEED

purgelist_amd_add_columns:
  project_id: pcb-{env}-landing
  dataset_id: domain_customer_acquisition
  table_name: PURGELIST_ADM
  transformations:
    - column:
        add_columns:
          - String(null) as PURGE_CYCLE
          - "'N' as IS_TERMINUS"

purgelist_experian_add_columns:
  dataset_id: domain_customer_acquisition
  project_id: pcb-{env}-landing
  table_name: PURGELIST_EXPERIAN
