  transformations:
    - column:
        add_columns:
          - TIMESTAMP(WEB_LAST_LOGIN_DATE , 'America/Toronto') AS WEB_LAST_LOGIN_DATE
          - TIMESTAMP(MOBILE_LAST_LOGIN_DATE , 'America/Toronto') AS MOBILE_LAST_LOGIN_DATE
          - TIMESTAMP(CREATE_DT , 'America/Toronto') AS CREATE_DT
          - TIMESTAMP(UPDATE_DT , 'America/Toronto') AS UPDATE_DT
        drop_columns:
          - WEB_LAST_LOGIN_DATE
          - MOBILE_LAST_LOGIN_DATE
          - CREATE_DT
          - UPDATE_DT

