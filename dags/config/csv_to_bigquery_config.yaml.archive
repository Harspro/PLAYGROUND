aml_ref_experian_country_code_loading_job:
  default_args:
    owner: "team-defenders-alerts"
  tags: ["P3"]
  source_file:
    bucket: COMPOSER_BUCKET
    name: dags/aml_processing/ref_tables/REF_EXPERIAN_COUNTRY_CODE.csv
    csv_options:
      skip_leading_rows: 1
      field_delimiter: ","
      max_bad_records: 0
    schema_external:
      - {"name": "ID1PLACE", "type": "STRING", "mode": "NULLABLE"}
      - {"name": "PROVINCE", "type": "STRING", "mode": "NULLABLE" }
      - {"name": "COUNTRY_CODE_3", "type": "STRING", "mode": "NULLABLE"}
      - {"name": "COUNTRY_CODE_2", "type": "STRING", "mode": "NULLABLE" }
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_aml
    table_name: REF_EXPERIAN_ID_PLACE
    data_load_type: FULL_REFRESH

aml_account_status_description_loading_job:
