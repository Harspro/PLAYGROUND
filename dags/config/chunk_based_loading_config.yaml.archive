      - TRIG_OUTCOME AS RD_FO_TRIG_OUTCOME
      - CAST(TRIG_NUM AS INT64) AS RD_FO_TRIG_NUM
      - CAST(SCEN_ID AS INT64) AS RD_FO_SCEN_ID
      - ACTION_1 AS RD_FO_ACTION_1
      - ACTION_2 AS RD_FO_ACTION_2
      - ACTION_3 AS RD_FO_ACTION_3
      - ACTION_4 AS RD_FO_ACTION_4
      - ACTION_5 AS RD_FO_ACTION_5
      - ACTION_6 AS RD_FO_ACTION_6
      - ACTION_7 AS RD_FO_ACTION_7
      - ACTION_8 AS RD_FO_ACTION_8
      - ACTION_9 AS RD_FO_ACTION_9
      - ACTION_10 AS RD_FO_ACTION_10
      - ACTION_11 AS RD_FO_ACTION_11
      - ACTION_12 AS RD_FO_ACTION_12
      - ACTION_13 AS RD_FO_ACTION_13
      - ACTION_14 AS RD_FO_ACTION_14
      - ACTION_15 AS RD_FO_ACTION_15
      - ACTION_16 AS RD_FO_ACTION_16
      - ACTION_17 AS RD_FO_ACTION_17
      - ACTION_18 AS RD_FO_ACTION_18
      - ACTION_19 AS RD_FO_ACTION_19
      - ACTION_20 AS RD_FO_ACTION_20
      - ACTION_21 AS RD_FO_ACTION_21
      - ACTION_22 AS RD_FO_ACTION_22
      - ACTION_23 AS RD_FO_ACTION_23
      - ACTION_24 AS RD_FO_ACTION_24
      - ACTION_25 AS RD_FO_ACTION_25
      - CAST(SCRD_ID AS INT64) AS RD_FO_SCRD_ID
      - CAST(ALIGNED_SCORE AS INT64) AS RD_FO_ALIGNED_SCORE
      - IF(BAR_FACTOR < 0, '-', '+') AS RD_FO_BAR_FTR_SIGN
      - CAST(ABS(BAR_FACTOR) AS INT64) AS RD_FO_BAR_FACTOR
      - CAST(SCORE_1 AS INT64) AS RD_FO_SCORE_1
      - CAST(SCORE_2 AS INT64) AS RD_FO_SCORE_2
      - IF(PERF_MEASURE_1 < 0, '-', '+') AS RD_FO_PERF_MEASURE_1_SIGN
      - CAST(ABS(PERF_MEASURE_1) AS INT64) AS RD_FO_PERF_MEASURE_1
      - IF(PERF_MEASURE_2 < 0, '-', '+') AS RD_FO_PERF_MEASURE_2_SIGN
      - CAST(ABS(PERF_MEASURE_2) AS INT64) AS RD_FO_PERF_MEASURE_2
      - IF(PERF_MEASURE_3 < 0, '-', '+') AS RD_FO_PERF_MEASURE_3_SIGN
      - CAST(ABS(PERF_MEASURE_3) AS INT64) AS RD_FO_PERF_MEASURE_3
      - IF(PERF_MEASURE_4 < 0, '-', '+') AS RD_FO_PERF_MEASURE_4_SIGN
      - CAST(ABS(PERF_MEASURE_4) AS INT64) AS RD_FO_PERF_MEASURE_4
      - IF(PERF_MEASURE_5 < 0, '-', '+') AS RD_FO_PERF_MEASURE_5_SIGN
      - CAST(ABS(PERF_MEASURE_5) AS INT64) AS RD_FO_PERF_MEASURE_5
      - IF(PERF_MEASURE_6 < 0, '-', '+') AS RD_FO_PERF_MEASURE_6_SIGN
      - CAST(ABS(PERF_MEASURE_6) AS INT64) AS RD_FO_PERF_MEASURE_6
      - IF(PERF_MEASURE_7 < 0, '-', '+') AS RD_FO_PERF_MEASURE_7_SIGN
      - CAST(ABS(PERF_MEASURE_7) AS INT64) AS RD_FO_PERF_MEASURE_7
      - IF(PERF_MEASURE_8 < 0, '-', '+') AS RD_FO_PERF_MEASURE_8_SIGN
      - CAST(ABS(PERF_MEASURE_8) AS INT64) AS RD_FO_PERF_MEASURE_8
      - IF(PERF_MEASURE_9 < 0, '-', '+') AS RD_FO_PERF_MEASURE_9_SIGN
      - CAST(ABS(PERF_MEASURE_9) AS INT64) AS RD_FO_PERF_MEASURE_9
      - IF(PERF_MEASURE_10 < 0, '-', '+') AS RD_FO_PERF_MEASURE_10_SIGN
      - CAST(ABS(PERF_MEASURE_10) AS INT64) AS RD_FO_PERF_MEASURE_10
      - IF(PERF_MEASURE_11 < 0, '-', '+') AS RD_FO_PERF_MEASURE_11_SIGN
      - CAST(ABS(PERF_MEASURE_11) AS INT64) AS RD_FO_PERF_MEASURE_11
      - IF(PERF_MEASURE_12 < 0, '-', '+') AS RD_FO_PERF_MEASURE_12_SIGN
      - CAST(ABS(PERF_MEASURE_12) AS INT64) AS RD_FO_PERF_MEASURE_12
      - CAST(INTERNAL_TRIGGER AS STRING FORMAT '0000FM') AS RD_FO_INTERNAL_TRIGGER
      - CURRENT_DATETIME('America/Toronto') AS REC_LOAD_TIMESTAMP
      - CURRENT_DATETIME('America/Toronto') AS REC_CHNG_TMS
      - "'Oracle P053 TS2.CDA_RECORDS_OUTCOMES' AS REC_CHNG_ID"
      - CAST(FORMAT_DATETIME('%Y%m%d%H%M%S', CURRENT_DATETIME('America/Toronto')) AS INTEGER) AS BATCH_RUN_LOG_UID
      - PARSE_DATE('%Y%d%m',SUBSTR(SN,1,8)) AS FILE_CREATE_DT
    drop_columns: '*'
