  batch:
    chunk_size_in_months: 6 # Valid range: 1 to 12 months
    start_date: 2017-01-01 # inclusive
    end_date: 2023-12-06 # exclusive
  default_args:
    owner: "team-money-movement-eng"
    capability: "Money Movement"
    sub_capability: "Triad History"
    business_impact: "Triad History one time load from Oracle to GCP. Credit Risk teams will need the data"
    customer_impact: "One time load. No impact"

ts2_triad_decision_keys_idl:
  fetch_spark_job:
    dbname: db053_money_movement
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.DECISION_KEYS
      pcb.bigquery.loader.source.db.read.parallelism: 4
      pcb.bigquery.loader.source.partition.column: PROC_DATE
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: TSYS_TRIAD_DECISION_KEYS_RPT
