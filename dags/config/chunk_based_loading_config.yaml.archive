      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.AH31
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_LOAD_DT_TM_STAMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: AH31
    partition_field: DATE_TRUNC(FILE_CREATE_DT, MONTH)
    clustering_fields:
      - MAST_ACCOUNT_ID
      - AH00_APPLICATION_SUFFIX
    add_columns:
      - PARSE_DATE('%Y%m%d', CAST(10000*YYYY + 100*MM + DD AS STRING)) AS FILE_CREATE_DT
      - IF(AH01_CDATE_CYCLE IS NOT NULL AND AH01_CDATE_CYCLE>0, PARSE_DATE('%E4Y%j', CAST(10000000-AH01_CDATE_CYCLE AS STRING)), SAFE_CAST(NULL AS DATE)) AS AH01_CDATE_CYCLE
      - REC_LOAD_DT_TM_STAMP AS REC_LOAD_TIMESTAMP
    drop_columns:
      - YYYY
      - MM
      - DD
      - REC_LOAD_DT_TM_STAMP
      - AH01_CDATE_CYCLE
  batch:
    chunk_size_in_months: 2 # Valid range: 1 to 12 months
    start_date: 2010-07-01 # inclusive
    end_date: 2016-01-01 # exclusive

