      - CAST(SPID AS INT64) AS RD_HD_SPID
      - CAST(DGTS_LOWLMT AS INT64) AS RD_HD_DGTS_LOWLMT
      - CAST(DGTS_UPLMT AS INT64) AS RD_HD_DGTS_UPLMT
      - FORMAT_DATETIME("%Y%m%d", PROC_DATE) AS RD_HD_PROC_DATE_CYMD
      - CUSTOMER_ID AS RD_HD_CUSTOMER_ID
      - ACCOUNT_ID AS RD_HD_ACCOUNT_ID
      - CAST(TEST_DGTS AS INT64) AS RD_HD_TEST_DGTS
      - ACCT_CUST_IND AS RD_HD_ACCT_CUST_IND
      - CAST(CO_PROD_TYPE AS INT64) AS RD_HD_CO_PROD_TYPE
      - CALL_TYPE AS RD_HD_CALL_TYPE
      - SUBJECT_CODE AS RD_HD_SUBJECT_CODE
      - SEG_TYPE AS RD_HD_SEG_TYPE
      - CAST(STGY_ROW AS INT64) AS RD_FO_STGY_ROW
      - IF(SMPL_FTR < 0, '-', '+') AS RD_FO_SMPL_FTR_SIGN
