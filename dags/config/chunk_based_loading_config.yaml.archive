risk_credscore_tsysconfm_table_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: RISK.CREDSCORE_TSYSCONFM
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_TIMESTAMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_scoring
    table_name: CREDSCORE_TSYSCONFM
    partition_field: SC01_CDATE
    clustering_fields:
      - AM00_ACCOUNT_IDENTIFIER
      - SC01_SCORE_ALIGNED
      - SC01_SCORE_TYPE
    add_columns:
      - REC_TIMESTAMP AS REC_LOAD_TIMESTAMP
      - IF(SC01_CDATE IS NOT NULL AND SC01_CDATE>0, PARSE_DATE('%E4Y%j', CAST(SC01_CDATE AS STRING)), SAFE_CAST(NULL AS DATE)) AS SC01_CDATE
      - IF(SC01_CDATE IS NOT NULL AND SC01_CDATE>0, PARSE_DATE('%E4Y%j', CAST(SC01_CDATE AS STRING)), SAFE_CAST(NULL AS DATE)) AS FILE_CREATE_DT
      - IF(SC01_CTIME IS NOT NULL AND SC01_CTIME>0, REGEXP_REPLACE(FORMAT('%07d', CAST(SC01_CTIME AS INT64)), r'^([0-9]{2})([0-9]{2})([0-9]{3})$', '\\1:\\2:\\3'), SAFE_CAST(SC01_CTIME AS STRING)) AS SC01_CTIME
      - IF(SC01_DATE_SCORE_ADDED IS NOT NULL AND SC01_DATE_SCORE_ADDED>0, PARSE_DATE('%E4Y%j', CAST(SC01_DATE_SCORE_ADDED AS STRING)), SAFE_CAST(NULL AS DATE)) AS SC01_DATE_SCORE_ADDED
      - IF(SC01_TIME_SCORE_ADDED IS NOT NULL AND SC01_TIME_SCORE_ADDED>0, REGEXP_REPLACE(FORMAT('%07d', CAST(SC01_TIME_SCORE_ADDED AS INT64)), r'^([0-9]{2})([0-9]{2})([0-9]{3})$', '\\1:\\2:\\3'), SAFE_CAST(SC01_TIME_SCORE_ADDED AS STRING)) AS SC01_TIME_SCORE_ADDED
    drop_columns:
      - TSYSCONF_KEY
      - REC_TIMESTAMP
      - SC01_CDATE
      - SC01_CTIME
      - SC01_DATE_SCORE_ADDED
      - SC01_TIME_SCORE_ADDED
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 12 months
    start_date: 2016-01-01 # inclusive
    end_date: 2023-12-12 # exclusive

