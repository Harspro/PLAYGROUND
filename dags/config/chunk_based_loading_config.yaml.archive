      CAST(CUST_TEST_DGT_3 AS INT64) AS RD_AB_CUST_TEST_DGT_3,
      CAST(CUST_TEST_DGT_4 AS INT64) AS RD_AB_CUST_TEST_DGT_4,
      CURRENCY_TYPE AS RD_AB_CURRENCY_TYPE,
      CAST(TRANS_TYPE_RPT_GRP AS INT64) AS RD_AB_TRANS_TYPE_RPT_GRP,
      "IF(TRANS_AMT < 0, '-', '+') AS RD_AB_TRANS_AMT_SIGN",
      CAST(ABS(TRANS_AMT) AS NUMERIC) AS RD_AB_TRANS_AMT,
      CAST(TRANS_TYPE AS INT64) AS RD_AB_TRANS_TYPE,
      CAST(DELQ_COLL_QUEUE AS INT64) AS RD_AB_DELQ_COLL_QUEUE,
      CAST(AMT_MULTIPLIER AS INT64) AS RD_AB_AMT_MULTIPLIER,
      CAST(AUTH_DETAIL AS INT64) AS RD_AB_AUTH_DETAIL,
      CAST(STGY_IND_1 AS INT64) AS RD_AB_STGY_IND_1,
      CAST(STGY_IND_2 AS INT64) AS RD_AB_STGY_IND_2,
      CAST(STGY_IND_3 AS INT64) AS RD_AB_STGY_IND_3,
      CAST(STGY_IND_4 AS INT64) AS RD_AB_STGY_IND_4,
      CAST(STGY_ID_1 AS INT64) AS RD_AB_STGY_ID_1,
      CAST(STGY_ID_2 AS INT64) AS RD_AB_STGY_ID_2,
      CAST(STGY_ID_3 AS INT64) AS RD_AB_STGY_ID_3,
      CAST(STGY_ID_4 AS INT64) AS RD_AB_STGY_ID_4,
      CAST(ROUND_FACTOR AS INT64) AS RD_AB_ROUND_FACTOR,
      "IF(MAX_CUSHION_LICR_1 < 0, '-', '+') AS RD_AB_MAX_CUSHLICR_SIGN_1",
      CAST(ABS(MAX_CUSHION_LICR_1) AS INT64) AS RD_AB_MAX_CUSHION_LICR_1,
      "IF(MAX_CUSHION_LICS_1 < 0, '-', '+') AS RD_AB_MAX_CUSHLICS_SIGN_1",
      CAST(ABS(MAX_CUSHION_LICS_1) AS INT64) AS RD_AB_MAX_CUSHION_LICS_1,
      "IF(MAX_CUSHION_LICR_2 < 0, '-', '+') AS RD_AB_MAX_CUSHLICR_SIGN_2",
      CAST(ABS(MAX_CUSHION_LICR_2) AS INT64) AS RD_AB_MAX_CUSHION_LICR_2,
      "IF(MAX_CUSHION_LICS_2 < 0, '-', '+') AS RD_AB_MAX_CUSHLICS_SIGN_2",
      CAST(ABS(MAX_CUSHION_LICS_2) AS INT64) AS RD_AB_MAX_CUSHION_LICS_2,
      "IF(MAX_CUSHION_LICR_3 < 0, '-', '+') AS RD_AB_MAX_CUSHLICR_SIGN_3",
      CAST(ABS(MAX_CUSHION_LICR_3) AS INT64) AS RD_AB_MAX_CUSHION_LICR_3,
