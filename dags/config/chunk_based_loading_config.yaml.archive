tsys_credit_score_T0010_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: RISK.CREDSCORE_T0010
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_TIMESTAMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_scoring
    table_name: CREDSCORE_T0010
    partition_field: RANGE_BUCKET(CB_FILE_NUMBER, GENERATE_ARRAY(15000, 4815000, 1200))
    clustering_fields:
      - ACCOUNT_NUMBER
      - REC_LOAD_TIMESTAMP
    add_columns:
      - REC_TIMESTAMP AS REC_LOAD_TIMESTAMP
      - SAFE_CAST(CB_FILE_NUMBER AS INT64) AS CB_FILE_NUMBER
      - TRIM(ACCOUNT_NUMBER) AS ACCOUNT_NUMBER
    drop_columns:
      - T0010_KEY
      - PCB_FILE_NUMBER
      - REC_TIMESTAMP
      - CB_FILE_NUMBER
      - ACCOUNT_NUMBER
    join:
      project_id: pcb-{env}-landing
      dataset_id: domain_scoring
      table_name: CREDSCORE_FILEINFO
      output_columns:
        - DATE(t.FILE_CREATION_DATE_TIME) AS FILE_CREATE_DT
      join_columns:
        - from_col: s.CB_FILE_NUMBER
          to_col: t.CB_FILE_NUMBER
        - from_col: s.PCB_FILE_NUMBER
          to_col: t.PCB_FILE_NUMBER
      filters:
        - t.FILE_NAME_PREFIX IN ('expcbanktsystt.eqxcan.ds.SC10', 'expcbanktsyspd.eqxcan.ds.SC10')
  batch:
    chunk_size_in_months: 12 # Valid range: >0
    start_date: 2016-01-01 # inclusive
    end_date: 2024-01-01 # exclusive

