      - CAST(CB_SCORE_3 AS INT64) AS RD_SPR_CB_SCORE_3
      - CAST(CB_SCORE_4 AS INT64) AS RD_SPR_CB_SCORE_4
      - CAST(CB_SCORE_5 AS INT64) AS RD_SPR_CB_SCORE_5
      - CAST(CB_SCORE_6 AS INT64) AS RD_SPR_CB_SCORE_6
      - IF(PROFIT < 0, '-', '+') AS RD_SPR_PROFIT_SIGN
      - CAST(ABS(PROFIT) AS INT64) AS RD_SPR_PROFIT
      - IF(PROVISION < 0, '-', '+') AS RD_SPR_PROVISION_SIGN
      - CAST(ABS(PROVISION) AS INT64) AS RD_SPR_PROVISION
      - IF(CTO_L6M < 0, '-', '+') AS RD_SPR_CTO_L6M_SIGN
      - CAST(ABS(CTO_L6M) AS INT64) AS RD_SPR_CTO_L6M
      - CAST(SW_SPID AS INT64) AS RD_SPR_SW_SPID
      - CAST(SW_DGTS_LOWLMT AS INT64) AS RD_SPR_SW_DGTS_LOWLMT
      - CAST(SW_DGTS_UPLMT AS INT64) AS RD_SPR_SW_DGTS_UPLMT
      - CAST(SW_SCEN_ID AS INT64) AS RD_SPR_SW_SCEN_ID
      - CAST(SW_SCORE AS INT64) AS RD_SPR_SW_SCORE
      - CAST(SW_SCRD_ID AS INT64) AS RD_SPR_SW_SCRD_ID
      - CAST(SW_MISC AS INT64) AS RD_SPR_SW_MISC
      - BLOCK_CODE AS RD_SPR_BLOCK_CODE
      - CURRENT_DATETIME('America/Toronto') AS REC_LOAD_TIMESTAMP
      - CURRENT_DATETIME('America/Toronto') AS REC_CHNG_TMS
      - "'Oracle P053 TS2.PERFORMANCE_OUTCOMES' AS REC_CHNG_ID"
      - CAST(FORMAT_DATETIME('%Y%m%d%H%M%S', CURRENT_DATETIME('America/Toronto')) AS INTEGER) AS BATCH_RUN_LOG_UID
      - PARSE_DATE('%Y%d%m',SUBSTR(SN,1,8)) AS FILE_CREATE_DT
    drop_columns: '*'
  batch:
    chunk_size_in_months: 6 # Valid range: 1 to 12 months
    start_date: 2017-01-01 # inclusive
    end_date: 2023-10-01 # exclusive
  default_args:
    owner: "team-money-movement-eng"
    capability: "Money Movement"
    sub_capability: "Triad History"
    business_impact: "Triad History one time load from Oracle to GCP. Credit Risk teams will need the data"
    customer_impact: "One time load. No impact"

