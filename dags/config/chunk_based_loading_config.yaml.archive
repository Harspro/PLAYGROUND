tsys_credit_score_das_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: RISK.CREDSCORE_DAS
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: DAS_KEY
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_scoring
    table_name: CREDSCORE_DAS
    partition_field: RANGE_BUCKET(CB_FILE_NUMBER, GENERATE_ARRAY(15000, 4815000, 1200))
    clustering_fields:
      - MAST_ACCOUNT_ID
      - AM00_APPLICATION_SUFFIX
    add_columns:
      - SAFE_CAST(CB_FILE_NUMBER AS INT64) AS CB_FILE_NUMBER
      - TRIM(AM01_ACCOUNT_NUM) AS AM01_ACCOUNT_NUM
    drop_columns:
      - REC_CHNG_TMS
      - DAS_KEY
      - PCB_FILE_NUMBER
      - CB_FILE_NUMBER
      - AM01_ACCOUNT_NUM
    join:
      project_id: pcb-{env}-landing
      dataset_id: domain_scoring
      table_name: CREDSCORE_FILEINFO
      output_columns:
        - DATE(t.FILE_CREATION_DATE_TIME) AS FILE_CREATE_DT
        - t.REC_LOAD_TIMESTAMP
      join_columns:
        - from_col: SAFE_CAST(s.CB_FILE_NUMBER AS NUMERIC)
          to_col: SAFE_CAST(t.CB_FILE_NUMBER AS NUMERIC)
        - from_col: s.PCB_FILE_NUMBER
          to_col: t.PCB_FILE_NUMBER
      filters:
        - t.FILE_NAME_PREFIX IN ('expcbanktsystt.eqxcan.ds.SCDS', 'expcbanktsyspd.eqxcan.ds.SCDS')
  batch:
    chunk_size_in_row_count: 5000000 # Valid range: >0
    lower_bound: 100 # inclusive
    upper_bound: 6000000 # exclusive

