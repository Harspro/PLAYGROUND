    dataset_id: domain_account_management
    table_name: STMT_FEEDBACK_STAGING
    partition_field: DATE_TRUNC(PROCESSED_TMS, MONTH)
    clustering_fields:
      - ACCOUNT_ID
      - CUSTOMER_ID
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 12 months
    start_date: 2014-01-01 # inclusive
    end_date: 2025-07-30 # exclusive
