ts2_triad_collection_outcomes_idl:
  fetch_spark_job:
    dbname: db053_money_movement
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.COLLECTION_OUTCOMES
      pcb.bigquery.loader.source.db.read.parallelism: 2
      pcb.bigquery.loader.source.partition.column: PROC_DATE
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: TSYS_COLLECTION_OUTCOMES_TRIAD_RPT
    add_columns:
      - TRR_LENGTH AS TRR_LENGTH
      - CAST(CLIENT_ID AS INT64) AS RD_HD_CLIENT_ID
      - CAST(SPID AS INT64) AS RD_HD_SPID
      - CAST(DGTS_LOWLMT AS INT64) AS RD_HD_DGTS_LOWLMT
      - CAST(DGTS_UPLMT AS INT64) AS RD_HD_DGTS_UPLMT
      - FORMAT_DATETIME("%Y%m%d", PROC_DATE) AS RD_HD_PROC_DATE_CYMD
      - CUSTOMER_ID AS RD_HD_CUSTOMER_ID
      - ACCOUNT_ID AS RD_HD_ACCOUNT_ID
      - CAST(TEST_DGTS AS INT64) AS RD_HD_TEST_DGTS
      - ACCT_CUST_IND AS RD_HD_ACCT_CUST_IND
      - CAST(CO_PROD_TYPE AS INT64) AS RD_HD_CO_PROD_TYPE
      - CALL_TYPE AS RD_HD_CALL_TYPE
      - SUBJECT_CODE AS RD_HD_SUBJECT_CODE
      - SEG_TYPE AS RD_HD_SEG_TYPE
      - CAST(STGY_ROW AS INT64) AS RD_EO_STGY_ROW
      - IF(SMPL_FTR < 0, '-', '+') AS RD_EO_SMPL_FTR_SIGN
      - CAST(ABS(SMPL_FTR) AS INT64) AS RD_EO_SMPL_FTR
      - SORT_1 AS RD_EO_SORT_1
      - CAST(SORT_2 AS INT64) AS RD_EO_SORT_2
      - CAST(EXCLUSION_IND AS INT64) AS RD_EO_EXCLUSION_IND
      - CAST(LVL_DELQ AS INT64) AS RD_EO_LVL_DELQ
      - CAST(LVL_DELQ_LC AS INT64) AS RD_EO_LVL_DELQ_LC
      - IF(BILL_BAL < 0, '-', '+') AS RD_EO_BILL_BAL_SIGN
      - CAST(ABS(BILL_BAL) AS INT64) AS RD_EO_BILL_BAL
      - PROCESS_SWITCH AS RD_EO_PROCESS_SWITCH
      - CAST(SCEN_ID AS INT64) AS RD_EO_SCEN_ID
      - IF(ACTION_CTR < 0, '-', '+') AS RD_EO_ACTION_CTR_SIGN
      - CAST(ABS(ACTION_CTR) AS INT64) AS RD_EO_ACTION_CTR
      - COLL_IND AS RD_EO_COLL_IND
      - BLK_CODE AS RD_EO_BLK_CODE
      - LTR_ID AS RD_EO_LTR_ID
      - TIMED_ACTION_4 AS RD_EO_TIMED_ACTION_4
      - TIMED_ACTION_5 AS RD_EO_TIMED_ACTION_5
      - FIXED_ACTION_1 AS RD_EO_FIXED_ACTION_1
      - FIXED_ACTION_2 AS RD_EO_FIXED_ACTION_2
      - CAST(RECLASS_OLD_SCEN_ID AS INT64) AS RD_EO_RECLASS_OLD_SCEN_ID
      - RECLASS_ATTEMPTED AS RD_EO_RECLASS_ATTEMPTED
      - CAST(LVL_DELQ_PRE_POST AS INT64) AS RD_EO_LVL_DELQ_PRE_POST
      - CAST(DAYS_SNC_SCEN_ASSIGNED AS INT64) AS RD_EO_DAYS_SNC_SCEN_ASSIGNED
      - CAST(RECLASS_INDICATOR AS INT64) AS RD_EO_RECLASS_INDICATOR
      - CAST(RECLASS_REASON AS INT64) AS RD_EO_RECLASS_REASON
      - CAST(STGY_ID AS INT64) AS RD_EO_STGY_ID
      - CAST(DAYS_SNC_SCEN_CATEGORY AS INT64) AS RD_EO_DAYS_SNC_SCEN_CATEGORY
      - CAST(ALIGNED_SCORE AS INT64) AS RD_EO_ALIGNED_SCORE
      - IF(BAR_FACTOR < 0, '-', '+') AS RD_EO_BAR_FACTOR_SIGN
      - CAST(ABS(BAR_FACTOR) AS INT64) AS RD_EO_BAR_FACTOR
      - IF(CCO_BAR_BALANCE < 0, '-', '+') AS RD_EO_CCO_BAR_BALANCE_SIGN
      - CAST(ABS(CCO_BAR_BALANCE) AS INT64) AS RD_EO_CCO_BAR_BALANCE
      - IF(CO_AMT_ARREARS < 0, '-', '+') AS RD_EO_CO_AMT_ARREARS_SIGN
      - CAST(ABS(CO_AMT_ARREARS) AS INT64) AS RD_EO_CO_AMT_ARREARS
      - IF(CO_LIMIT < 0, '-', '+') AS RD_EO_CO_LIMIT_SIGN
      - CAST(ABS(CO_LIMIT) AS INT64) AS RD_EO_CO_LIMIT
      - CAST(EO_CO_PROD_TYPE AS INT64) AS RD_EO_CO_PROD_TYPE
      - CURRENT_DATETIME('America/Toronto') AS REC_LOAD_TIMESTAMP
      - CURRENT_DATETIME('America/Toronto') AS REC_CHNG_TMS
      - "'Oracle P053 TS2.COLLECTION_OUTCOMES' AS REC_CHNG_ID"
      - CAST(FORMAT_DATETIME('%Y%m%d%H%M%S', CURRENT_DATETIME('America/Toronto')) AS INTEGER) AS BATCH_RUN_LOG_UID
      - PARSE_DATE('%Y%d%m',SUBSTR(SN,1,8)) AS FILE_CREATE_DT
    drop_columns: '*'
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 12 months
    start_date: 2017-01-01 # inclusive
    end_date: 2023-07-01 # exclusive
  default_args:
    owner: "team-money-movement-eng"
    capability: "Money Movement"
    sub_capability: "Triad History"
    business_impact: "Triad History one time load from Oracle to GCP. Credit Risk teams will need the data"
    customer_impact: "One time load. No impact"

