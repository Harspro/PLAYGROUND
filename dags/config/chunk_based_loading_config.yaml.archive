# Batch loading dag configs
ts2_at31_table_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.AT31
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_LOAD_DT_TM_STAMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: AT31
    partition_field: FILE_CREATE_DT
    clustering_fields:
      - MAST_ACCOUNT_ID
      - AT31_DATE_TRANSACTION
      - AT31_TRANSACTION_CODE
      - AT31_MERCHANT_ID
    add_columns:
      - PARSE_DATE('%Y%m%d', CAST(10000*YYYY + 100*MM + DD AS STRING)) AS FILE_CREATE_DT
      - REC_LOAD_DT_TM_STAMP AS REC_LOAD_TIMESTAMP
    drop_columns:
      - YYYY
      - MM
      - DD
      - REC_LOAD_DT_TM_STAMP
      - AT31_DESIGNATED_PROMO_LENDING
  batch:
    chunk_size_in_months: 2 # Valid range: 1 to 6 months
    start_date: 2017-01-01 # inclusive
    end_date: 2018-01-01 # exclusive

ts2_cardguard_caselog_table_idl:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.CARDGUARD_CASELOG
      pcb.bigquery.loader.source.db.read.parallelism: 1
      pcb.bigquery.loader.source.partition.column: REC_LOAD_DT_TM_STMP
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_fraud
    table_name: CARDGUARD_CASELOG
    clustering_fields:
      - ACCOUNT_NUMBER
    add_columns:
      - PARSE_DATE('%Y%m%d', CAST(10000*YYYY + 100*MM + DD AS STRING)) AS FILE_CREATE_DT
      - REC_LOAD_DT_TM_STMP AS REC_LOAD_TIMESTAMP
    drop_columns:
      - YYYY
      - MM
      - DD
      - REC_LOAD_DT_TM_STMP
  batch:
    chunk_size_in_months: 6 # Valid range: 1 to 6 months
    start_date: 2017-01-01 # inclusive
    end_date: 2018-01-01 # exclusive

adm_app_log_head_trail_table_idl:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: ADM.APP_LOG_HEAD_TRAIL
      pcb.bigquery.loader.source.db.read.parallelism: 1
      pcb.bigquery.loader.source.partition.column: REC_LOAD_TMS
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_customer_acquisition
    table_name: APP_LOG_HEAD_TRAIL
    add_columns:
      - V9SEQ AS EXECUTION_ID
      - DATE(APP_LOG_EXTR_DT) AS FILE_CREATE_DT
    drop_columns:
      - V9SEQ
      - APP_LOG_EXTR_DT
      - LOAD_RESULT_UUID
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 6 months
    start_date: 2015-01-01 # inclusive
    end_date: 2023-03-31 # exclusive

adm_gen_val_detail_idl:
  fetch_spark_job:
    dbname: db053
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: ADM.GEN_VAL_DETAIL
      pcb.bigquery.loader.source.db.read.parallelism: 8
      pcb.bigquery.loader.source.partition.column: REC_LOAD_TMS
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_customer_acquisition
    table_name: GEN_VAL_DETAIL
    partition_field: DATE_TRUNC(FILE_CREATE_DT, MONTH)
    clustering_fields:
      - APP_NUM
      - ELEMENT_NAME
    add_columns:
      - V9SEQ AS EXECUTION_ID
    drop_columns:
      - V9SEQ
      - LOAD_RESULT_UUID
    join:
      table_name: LOAD_RESULT
      output_columns:
        - FILE_CREATE_DT
      join_columns:
        - from_colum: EXECUTION_ID
          to_column: EXECUTION_ID
      filters:
        - column_name: TABLE_NM
          column_value: GEN_VAL_DETAIL
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 6 months
    start_date: 2015-10-01 # inclusive
    end_date: 2023-03-31 # exclusive

