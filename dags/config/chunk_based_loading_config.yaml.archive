cme_customer_media_table_idl:
  fetch_spark_job:
    dbname: db303
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: LDS_CME.CUSTOMER_MEDIA
      pcb.bigquery.loader.source.db.read.parallelism: 12
      pcb.bigquery.loader.source.partition.column: REC_CREATE_TMS
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_marketing
    table_name: CUSTOMER_MEDIA
    partition_field: DATETIME_TRUNC(REC_CREATE_TMS, MONTH)
    clustering_fields:
      - customer_media_ref
  batch:
    chunk_size_in_months: 12 # Valid range: 1 to 12 months
    start_date: 2013-01-01 # inclusive
    end_date: 2024-02-12 # exclusive
  default_args:
    owner: "team-centaurs"
    capability: "Data Movement PDS"
    sub_capability: "PDS"
    business_impact: "Potential compliance issue due to delay in loading business data"
    customer_impact: "Delay in loading business data"

