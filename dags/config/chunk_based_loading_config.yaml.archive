ts2_triad_auth_base_idl:
  fetch_spark_job:
    dbname: db053_money_movement
    args:
      pcb.bigquery.loader.source.schema.qualified.tablename: TS2.AUTHORIZATIONS_BASE
      pcb.bigquery.loader.source.db.read.parallelism: 4
      pcb.bigquery.loader.source.partition.column: PROC_DATE
  bigquery:
    project_id: pcb-{env}-landing
    dataset_id: domain_account_management
    table_name: TSYS_AUTHORIZATION_BASE_TRIAD_RPT
    add_columns: [
      TRR_LENGTH AS TRR_LENGTH,
      CAST(CLIENT_ID AS INT64) AS RD_HD_CLIENT_ID,
      CAST(SPID AS INT64) AS RD_HD_SPID,
      CAST(DGTS_LOWLMT AS INT64) AS RD_HD_DGTS_LOWLMT,
      CAST(DGTS_UPLMT AS INT64) AS RD_HD_DGTS_UPLMT,
      FORMAT_DATETIME("%Y%m%d", PROC_DATE) AS RD_HD_PROC_DATE_CYMD,
      CUSTOMER_ID AS RD_HD_CUSTOMER_ID,
      ACCOUNT_ID AS RD_HD_ACCOUNT_ID,
      CAST(TEST_DGTS AS INT64) AS RD_HD_TEST_DGTS,
      ACCT_CUST_IND AS RD_HD_ACCT_CUST_IND,
      CAST(CO_PROD_TYPE AS INT64) AS RD_HD_CO_PROD_TYPE,
      CALL_TYPE AS RD_HD_CALL_TYPE,
      SUBJECT_CODE AS RD_HD_SUBJECT_CODE,
      SEG_TYPE AS RD_HD_SEG_TYPE,
      CAST(PROC_TIME_STAMP AS INT64) AS RD_AB_PROC_TIME_STAMP,
      "IF(SMPL_FTR < 0, '-', '+') AS RD_AB_SMPL_FTR_SIGN",
      CAST(ABS(SMPL_FTR) AS INT64) AS RD_AB_SMPL_FTR,
      CAST(AUTH_RPT_REC_TYPE AS INT64) AS RD_AB_AUTH_RPT_REC_TYPE,
      CAST(ALIGNED_SCORE AS INT64) AS RD_AB_ALIGNED_SCORE,
      CAST(CB_SCORE AS INT64) AS RD_AB_CB_SCORE,
      "IF(LICR < 0, '-', '+') AS RD_AB_LICR_SIGN",
      CAST(ABS(LICR) AS INT64) AS RD_AB_LICR,
      "IF(CURR_BAL < 0, '-', '+') AS RD_AB_CURR_BAL_SIGN",
      CAST(ABS(CURR_BAL) AS INT64) AS RD_AB_CURR_BAL,
      "IF(OUTSTD_AUTH < 0, '-', '+') AS RD_AB_OUTSTD_AUTH_SIGN",
      CAST(ABS(OUTSTD_AUTH) AS INT64) AS RD_AB_OUTSTD_AUTH,
      "IF(LICS < 0, '-', '+') AS RD_AB_LICS_SIGN",
      CAST(ABS(LICS) AS INT64) AS RD_AB_LICS,
      "IF(CURR_CASH_BAL < 0, '-', '+') AS RD_AB_CURR_CASH_BAL_SIGN",
      CAST(ABS(CURR_CASH_BAL) AS INT64) AS RD_AB_CURR_CASH_BAL,
      CAST(RAW_SCORE AS INT64) AS RD_AB_RAW_SCORE,
      CAST(BEHAVIOR_SCRD_ID AS INT64) AS RD_AB_BEHAVIOR_SCRD_ID,
      "IF(AMT_AT_RISK_FACTOR < 0, '-', '+') AS RD_AB_AMT_AT_RISK_FACTOR_SIGN",
