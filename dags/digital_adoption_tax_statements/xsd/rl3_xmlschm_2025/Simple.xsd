	<!--    Types pour des éléments particuliers				   -->
	<!--                                                           -->
	<xsd:simpleType
    name="CodePostalType">
		
		<xsd:restriction
      base="xsd:string">
			<xsd:minLength
        value="1" />
			<xsd:maxLength
        value="6" />
		</xsd:restriction>
		<!-- Note: Le format du code postal canadien n'est pas spécifié car ce 
			 type doit aussi accepter un code zip américain. -->
	</xsd:simpleType>
	<xsd:simpleType
    name="CodePostalCanadienType">
		
		<xsd:restriction
      base="xsd:string">
			<xsd:pattern
        value="[a-zA-Z][0-9][a-zA-Z][0-9][a-zA-Z][0-9]" />
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType
    name="LangueType">
		
		<xsd:restriction
      base="xsd:string">
			<xsd:enumeration
        value="A" />
			<xsd:enumeration
        value="F" />
			<xsd:enumeration
        value="a" />
			<xsd:enumeration
        value="f" />
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType
    name="TelType">
		
		<xsd:restriction
      base="xsd:string">
			<xsd:pattern
        value="\d{3}-\d{4}" />
