              name="CodePermanent">
							
							<xsd:simpleType>
								<xsd:restriction
                  base="Char12Type">
									<xsd:pattern
                    value="([A-Z]{4}|[a-z]{4})\d{8}" />
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<xsd:element
              name="NomFamille"
              type="Char30Type">
							
						</xsd:element>
						<xsd:element
              name="Prenom"
              type="Char30Type">
							
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
