    schemaLocation="SimpleEvolutif.xsd" />
	<!-- @@@@ Definition du D08 @@@@           -->
	<xsd:complexType
    name="D08Struct">
		<xsd:sequence>
			<xsd:element
        name="Annee"
        type="AnImpositionType">
				
			</xsd:element>
			<xsd:element
        name="NoReleve"
        type="NoReleveType">
				
			</xsd:element>
			<xsd:element
        name="Etudiant">
				
